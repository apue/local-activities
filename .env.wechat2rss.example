# Wechat2RSS local Docker environment.
# Copy to .env.wechat2rss and fill values on the Mac that will run Wechat2RSS.
# Keep this file local; do not commit .env.wechat2rss.

# Official image is ttttmr/wechat2rss. If Docker Hub is blocked, the upstream
# docs mention docker.xlab.app/ttttmr/wechat2rss:latest as an alternative.
WECHAT2RSS_IMAGE=ttttmr/wechat2rss:latest

# Bind only to localhost for the PoC. Do not expose the admin UI publicly.
WECHAT2RSS_BIND_HOST=127.0.0.1
WECHAT2RSS_PORT=4000
WECHAT2RSS_ENV_FILE=.env.wechat2rss

# First-start license settings from your Wechat2RSS private deployment account.
LIC_EMAIL=replace-with-license-email
LIC_CODE=replace-with-license-code

# Used by generated RSS links. For a local-only PoC, keep this aligned with
# WECHAT2RSS_BIND_HOST and WECHAT2RSS_PORT.
RSS_HOST=127.0.0.1:4000
RSS_HTTPS=0

# Service/API password. The local collector uses the same value as
# WECHAT2RSS_TOKEN in .env.collector.
RSS_TOKEN=replace-with-local-wechat2rss-token

# Keep feed IDs stable and avoid accidental public discovery.
RSS_ENC_FEED_ID=1
RSS_MAX_ITEM_COUNT=20
RSS_KEEP_OLD_COUNT=50
