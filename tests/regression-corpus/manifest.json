    },
    {
      "label": "duplicate_or_update",
      "reason": "The local cache contains duplicate URLs, but the current replay/eval harness is single-case and has no stateful candidate set for fair dedupe/update scoring."
    },
    {
      "label": "qr_present_not_registration",
      "reason": "No real captured article in the current local cache exposed a reliable footer/share QR image through the bundle contract."
    },
    {
      "label": "capture_failure",
      "reason": "Wechat2RSS was healthy during corpus rebuild, so no real login_required/captcha_required/fetch_blocked capture failure sample was available."
    }
