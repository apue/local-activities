# Local collector environment for the Mac that talks to Vercel and Wechat2RSS.
# Copy to .env.collector and fill values locally. Do not commit .env.collector.

# Vercel app/API boundary.
APP_BASE_URL=https://local-activities.vercel.app
COLLECTOR_BASE_URL=https://local-activities.vercel.app
COLLECTOR_API_KEY=replace-with-collector-api-key
COLLECTOR_ID=mac-local-collector
COLLECTOR_INTERVAL_HOURS=24

# Local Wechat2RSS provider. This should point to the Docker Compose service on
# the same Mac. WECHAT2RSS_TOKEN must match RSS_TOKEN in .env.wechat2rss.
WECHAT2RSS_BASE_URL=http://127.0.0.1:4000
WECHAT2RSS_TOKEN=replace-with-local-wechat2rss-token
WECHAT2RSS_LOOKBACK_DAYS=7

# The one-shot Wechat2RSS sync does not call LLMs. Keep provider values for
# later extraction/collector modes that require them.
AGENT_PROVIDER=openai
OPENAI_API_KEY=collector-side-provider-secret
OPENAI_MODEL=provider-model-name
OPENAI_BASE_URL=https://api.openai.com/v1
