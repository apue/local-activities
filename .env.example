# Local Activities environment template
# Copy to .env.local for Next.js/local app development or .env for other local tools.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
APP_ENV=local
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Local Activities"

# Protect admin-only routes/actions in the MVP before full user auth exists.
ADMIN_ACCESS_TOKEN=replace-with-random-admin-token

# Authenticates external capture workers calling Supabase Edge Functions.
COLLECTOR_EDGE_TOKEN=replace-with-random-collector-edge-token

# Shared secret for internal-only API calls and scheduled/orchestrated jobs.
INTERNAL_API_SECRET=replace-with-random-internal-secret

# -----------------------------------------------------------------------------
# Supabase / Postgres
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Preferred hosted Supabase API keys.
# Publishable keys are safe for browser/mobile clients when RLS is enforced.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-sb-publishable-key
SUPABASE_PUBLISHABLE_KEY=replace-with-sb-publishable-key

# Secret keys are server-only. Never expose these through NEXT_PUBLIC_ variables.
SUPABASE_SECRET_KEY=replace-with-sb-secret-key

# Legacy JWT API keys and compatibility names. Keep these while Supabase CLI,
# older examples, or local tooling still expect anon/service_role values.
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-legacy-supabase-anon-key
SUPABASE_ANON_KEY=replace-with-legacy-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-legacy-supabase-service-role-key

# Local/self-hosted Auth JWT secret. Hosted projects usually manage this in the
# Supabase dashboard; local Supabase CLI stacks derive their own local values.
JWT_SECRET=replace-with-local-or-self-hosted-jwt-secret-if-needed
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Optional direct or migration connection string if different from DATABASE_URL.
SUPABASE_DB_DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Supabase Storage buckets used by the reset pipeline.
ARTICLE_BUNDLES_BUCKET=article-bundles
EVENT_EVIDENCE_ASSETS_BUCKET=event-evidence-assets
EVAL_ARTIFACTS_BUCKET=eval-artifacts

# Supabase CLI local aliases, compatible with `supabase status --output env`.
# Use these for scripts that target the local Docker stack instead of hosted
# Supabase. Values below are placeholders for the default local ports.
SUPA_API_URL=http://127.0.0.1:54321
SUPA_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPA_ANON_KEY=replace-with-local-supa-anon-key
SUPA_SERVICE_KEY=replace-with-local-supa-service-key

# -----------------------------------------------------------------------------
# Map / geocoding provider: AMAP assumed for China MVP
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAP_PROVIDER=amap
NEXT_PUBLIC_MAP_COORDINATE_SYSTEM=GCJ02

# Browser-side AMAP JS key for map display. Keep this key domain-restricted.
NEXT_PUBLIC_AMAP_JS_API_KEY=replace-with-amap-js-api-key

# Server-side AMAP Web Service key for geocoding and place lookup.
AMAP_WEB_SERVICE_API_KEY=replace-with-amap-web-service-api-key
AMAP_SECURITY_JS_CODE=replace-with-amap-security-js-code-if-used

# -----------------------------------------------------------------------------
# Supabase Edge Function LLM provider
# -----------------------------------------------------------------------------
# These values belong in Supabase Edge Function secrets for production. Local
# development may mirror them in `.env.local` when serving functions locally.
ANALYSIS_LLM_PROVIDER=openai_compatible
ANALYSIS_LLM_API_KEY=replace-with-provider-api-key
ANALYSIS_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ANALYSIS_LLM_MODEL=qwen3-vl-plus
ANALYSIS_LLM_API_STYLE=chat_completions
ANALYSIS_LLM_MAX_OUTPUT_TOKENS=8192
ANALYSIS_LLM_TIMEOUT_SECONDS=120
# Optional cost estimate used when the provider returns tokens but no cost.
# Values are CNY per 1M tokens for the active model/provider.
ANALYSIS_LLM_INPUT_PRICE_CNY_PER_1M=
ANALYSIS_LLM_OUTPUT_PRICE_CNY_PER_1M=

# Optional local V5 live evaluation override. If omitted, `pipeline:v5:eval`
# falls back to the ANALYSIS_LLM_* values above when `--variant live-configured`
# is explicitly enabled.
V5_LIVE_PROVIDER=openai-compatible
V5_LIVE_API_KEY=
V5_LIVE_BASE_URL=
V5_LIVE_MODEL=
V5_LIVE_MAX_TOKENS=1600
# Optional provider-specific body field. Leave empty unless the selected model
# supports it. SiliconFlow Qwen3.6 currently benefits from false.
V5_LIVE_ENABLE_THINKING=

# -----------------------------------------------------------------------------
# Text-to-speech: Cartesia or ElevenLabs candidates
# -----------------------------------------------------------------------------
TTS_PROVIDER=cartesia
TTS_API_BASE_URL=https://api.cartesia.ai
TTS_API_KEY=replace-with-tts-api-key
TTS_MODEL=sonic-2
TTS_VOICE_ID=replace-with-default-voice-id

# -----------------------------------------------------------------------------
# Web crawling / extraction providers
# -----------------------------------------------------------------------------
# Exa for search and page discovery.
EXA_BASE_URL=https://api.exa.ai
EXA_API_KEY=replace-with-exa-api-key

# Serper for search-engine-style result discovery.
SERPER_BASE_URL=https://google.serper.dev
SERPER_API_KEY=replace-with-serper-api-key

# Firecrawl for page crawling/scraping and search where allowed.
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_API_KEY=replace-with-firecrawl-api-key

# Optional external capture worker settings.
APP_BASE_URL=https://replace-with-vercel-app-url
COLLECTOR_ID=external-capture-worker-dev
COLLECTOR_INTERVAL_HOURS=4
CAPTURE_WORKER_POLL_INTERVAL_SECONDS=14400
CAPTURE_WORKER_STATE_FILE=.capture-worker-state.json
# Optional explicit Edge Function URL for local acceptance, for example a local
# Deno wrapper around supabase/functions/analyze-article-bundle.
ANALYZE_FUNCTION_URL=
ANALYZE_FUNCTION_TIMEOUT_MS=60000

# Local Wechat2RSS provider. Keep this service local to the collector machine;
# do not expose the Wechat2RSS admin UI or token publicly.
WECHAT2RSS_BASE_URL=http://127.0.0.1:4000
WECHAT2RSS_TOKEN=replace-with-wechat2rss-token
WECHAT2RSS_LOOKBACK_DAYS=7

# Optional local smoke-test proxy. These variables are read only by local smoke
# scripts, not by the deployed app runtime. Use them when browser traffic works
# through a local proxy but command-line requests to Vercel time out.
LOCAL_TEST_HTTP_PROXY=
LOCAL_TEST_HTTPS_PROXY=

# -----------------------------------------------------------------------------
# Vercel platform candidates
# -----------------------------------------------------------------------------
VERCEL_PROJECT_ID=replace-with-vercel-project-id
VERCEL_ORG_ID=replace-with-vercel-org-id-if-used
VERCEL_TEAM_ID=replace-with-vercel-team-id-if-needed-by-older-tools
VERCEL_TOKEN=replace-with-vercel-cli-token-if-needed
VERCEL_OIDC_TOKEN=replace-with-token-only-if-required-locally

# Vercel Cron calls should authenticate with this shared secret.
CRON_SECRET=replace-with-random-cron-secret

# Observation uses Vercel built-ins by default: dashboard logs, Observability,
# Web Analytics, and Speed Insights. Do not add third-party observability keys
# unless a later issue explicitly adopts one.
OBSERVABILITY_PROVIDER=vercel
VERCEL_WEB_ANALYTICS_ENABLED=true
VERCEL_SPEED_INSIGHTS_ENABLED=true

# Workflow may be used later for durable backend orchestration.
VERCEL_WORKFLOW_ENABLED=false
VERCEL_QUEUE_ENABLED=false

# -----------------------------------------------------------------------------
# Calendar export / sync
# -----------------------------------------------------------------------------
# Public base URL used when generating .ics links and event canonical URLs.
CALENDAR_PUBLIC_BASE_URL=http://localhost:3000
CALENDAR_PRODUCT_ID="-//Local Activities//Beijing Cultural Events//EN"
CALENDAR_DEFAULT_TIMEZONE=Asia/Shanghai

# Optional Google Calendar integration. Not required for basic add-to-calendar
# links or downloadable .ics feeds.
GOOGLE_CALENDAR_CLIENT_ID=replace-with-google-client-id-if-used
GOOGLE_CALENDAR_CLIENT_SECRET=replace-with-google-client-secret-if-used
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback

# -----------------------------------------------------------------------------
# MCP / agent tooling
# -----------------------------------------------------------------------------
MCP_CONTEXT7_ENABLED=true
CODEX_PROJECT_CONFIG=.codex/config.toml

# Project-level agent skills expected during implementation planning/review:
# - vercel-deployment
# - vercel-react-best-practices
# - supabase-postgres-best-practices
