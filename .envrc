# direnv configuration for Local Activities.
#
# Usage:
#   1. cp .env.example .env.local
#   2. edit .env.local with real local values
#   3. direnv allow
#
# This file intentionally loads local env files but does not contain secrets.

# Use the project-required Node.js 24 LTS when installed via Homebrew.
if [ -d /opt/homebrew/opt/node@24/bin ]; then
  PATH_add /opt/homebrew/opt/node@24/bin
fi

# Optionally support tools that expect .env.
if [ -f .env ]; then
  dotenv .env
fi

# Load the developer's private overrides last. This file is ignored by git.
if [ -f .env.local ]; then
  dotenv .env.local
fi

# Prefer pnpm-installed CLIs from node_modules/.bin when the app is scaffolded.
PATH_add node_modules/.bin
